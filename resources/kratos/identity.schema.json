{
  "$id": "https://schemas.ory.sh/presets/kratos/quickstart/email-password/identity.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Person",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "title": "Email",
          "minLength": 6,
          "ory.sh/kratos": {
            "credentials": {
              "password": {
                "identifier": true
              }
            }
          }
        },
        "name": {
          "type": "string",
          "format": "string",
          "title": "Name"
        },
        "photo": {
          "type": "string",
          "format": "string",
          "title": "Photo"
        },
        "dob": {
          "type": "string",
          "format": "string",
          "title": "Birthdate"
        },
        "phone": {
          "type": "string",
          "format": "string",
          "title": "Phone"
        }
      },
      "required": [
        "email"
      ],
      "additionalProperties": false
    }
  }
}
